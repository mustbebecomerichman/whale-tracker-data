# WhaleTracker Pro — 로컬 환경 변수 템플릿
# 이 파일을 복사해서 secrets_local.py 또는 .env.local 로 사용하세요.
# 절대 실제 값을 이 파일에 넣지 마세요 — .gitignore에 등록된 파일에만 보관하세요.

# ── DART Open API ──────────────────────────────────────────────
# 발급: https://opendart.fss.or.kr/ > 인증키 신청/관리
DART_API_KEY=your_dart_api_key_here

# ── Firebase 서비스 계정 ────────────────────────────────────────
# Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > 새 비공개 키 생성
# JSON 전체 내용을 한 줄로 직렬화하거나 파일 경로를 지정
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"whaletracker-pro",...}
# 또는 파일 경로 방식:
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# ── AdSense (승인 후 입력) ──────────────────────────────────────
# ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
# ADSENSE_SLOT_PORTFOLIO_MOBILE=XXXXXXXXXX

# ── AdMob (Play Store 등록 후 입력) ────────────────────────────
# ADMOB_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
# ADMOB_BANNER_UNIT_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# ── Android (TWA 빌드 시 필요) ─────────────────────────────────
# ANDROID_PACKAGE_NAME=com.whaletracker.pro
# ANDROID_SHA256_FINGERPRINT=AA:BB:CC:...
